const buildQueryString = (queryParams = {}) => {
  const params = new URLSearchParams();

  Object.entries(queryParams).forEach(([key, value]) => {
    const stringValue = String(value).trim();
    params.append(key, stringValue);
  });

  return `?${params.toString()}`;
};
